generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model lessons {
  id              Int     @id @default(autoincrement())
  subject         String  @db.VarChar(50)
  teacher         String  @db.VarChar(100)
  class_level     String  @db.VarChar(20)
  scheduled_hours Decimal @db.Decimal(4, 1)
  conducted_lessons conducted_lessons[]
}

model conducted_lessons {
  id Int @id @default(autoincrement())
  lesson_id Int
  conducted_date DateTime @default(now())
  lessons lessons @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
}